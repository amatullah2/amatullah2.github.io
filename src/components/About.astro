---
const stats = [
  { value: '2',    suffix: '+', label: 'Years Experience' },
  { value: '10',   suffix: '+', label: 'Projects Shipped' },
  { value: '3',    suffix: '',  label: 'Companies' },
  { value: '8.58', suffix: '',  label: 'CGPA', decimal: true },
];

const info = [
  { icon: '📍', label: 'Location',     value: 'Gujarat, India' },
  { icon: '🎓', label: 'Education',    value: 'BE Computer Science — SLTIET' },
  { icon: '💼', label: 'Current Role', value: 'React Native Developer at Wowsly' },
  { icon: '📧', label: 'Email',        value: 'amatullahbharmal3@gmail.com', href: 'mailto:amatullahbharmal3@gmail.com' },
];
---

<section id="about" class="py-24 relative">
  <div class="max-w-6xl mx-auto px-6">
    <div data-animate>
      <span class="section-label">01. about me</span>
      <h2 class="section-title">Who I Am</h2>
      <div class="section-bar"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <!-- Left: Text -->
      <div data-animate>
        <p class="text-slate-300 text-lg leading-relaxed mb-6">
          I'm a passionate <span class="text-white font-semibold">React Native Developer</span> and
          Computer Science graduate with hands-on experience building cross-platform mobile
          applications for real-world clients and companies.
        </p>
        <p class="text-slate-400 leading-relaxed mb-6">
          My expertise lies in creating smooth, scalable, and user-friendly apps — from event
          management platforms and food delivery apps to finance trackers and B2B solutions.
          I thrive at the intersection of clean architecture and great user experience.
        </p>
        <p class="text-slate-400 leading-relaxed mb-10">
          Currently, I'm working at <span class="text-violet-300 font-medium">Wowsly</span>, where I
          build and maintain a React Native event management platform featuring QR-code entry,
          ticket booking, and real-time attendee management.
        </p>

        <!-- Info list -->
        <ul class="space-y-4">
          {info.map((item) => (
            <li class="flex items-start gap-3">
              <span class="text-lg mt-0.5">{item.icon}</span>
              <div>
                <span class="text-xs font-mono text-slate-500 uppercase tracking-wider block">{item.label}</span>
                {item.href ? (
                  <a href={item.href} class="text-slate-300 hover:text-violet-300 transition-colors font-medium">
                    {item.value}
                  </a>
                ) : (
                  <span class="text-slate-300 font-medium">{item.value}</span>
                )}
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Right: Stats grid with count-up -->
      <div data-animate class="grid grid-cols-2 gap-4">
        {stats.map((stat) => (
          <div class="card p-6 text-center group">
            <div class="text-4xl font-extrabold gradient-text mb-2 group-hover:scale-110 transition-transform duration-300">
              <span
                class="count-up"
                data-target={stat.value}
                data-suffix={stat.suffix}
                data-decimal={stat.decimal ? 'true' : 'false'}
              >0{stat.suffix}</span>
            </div>
            <div class="text-sm text-slate-400 font-medium">{stat.label}</div>
          </div>
        ))}

        <!-- Languages card -->
        <div class="card p-6 col-span-2">
          <p class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-3">Languages Known</p>
          <div class="flex flex-wrap gap-2">
            {['English', 'Hindi', 'Gujarati'].map((lang) => (
              <span class="px-3 py-1 rounded-full bg-slate-800 border border-slate-700 text-slate-300 text-sm font-medium">
                {lang}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Count-up animation triggered when stats scroll into view
  document.querySelectorAll<HTMLElement>('.count-up').forEach((el) => {
    const target  = parseFloat(el.dataset.target  ?? '0');
    const suffix  = el.dataset.suffix ?? '';
    const decimal = el.dataset.decimal === 'true';
    let started   = false;

    const run = () => {
      if (started) return;
      started = true;

      const duration = 1800;
      const steps    = 60;
      const interval = duration / steps;
      let step       = 0;

      const timer = setInterval(() => {
        step++;
        const progress = step / steps;
        // ease-out quad
        const eased = 1 - (1 - progress) * (1 - progress);
        const current = target * eased;
        el.textContent = (decimal ? current.toFixed(2) : Math.floor(current)) + suffix;
        if (step >= steps) {
          clearInterval(timer);
          el.textContent = (decimal ? target.toFixed(2) : target) + suffix;
        }
      }, interval);
    };

    const obs = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) { run(); obs.disconnect(); }
    }, { threshold: 0.5 });

    obs.observe(el);
  });
</script>
