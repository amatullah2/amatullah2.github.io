---
---

<section
  id="hero"
  class="relative min-h-screen flex items-center overflow-hidden pt-20"
>
  <!-- ── Animated background ── -->
  <div class="absolute inset-0 bg-slate-950">
    <!-- Drifting orbs -->
    <div class="absolute top-1/4 -left-40 w-[520px] h-[520px] bg-violet-600/18 rounded-full blur-[110px] animate-orb-a pointer-events-none"></div>
    <div class="absolute bottom-1/4 -right-40 w-[520px] h-[520px] bg-blue-600/18 rounded-full blur-[110px] animate-orb-b pointer-events-none"></div>
    <div class="absolute top-3/4 left-1/3 w-[320px] h-[320px] bg-fuchsia-600/10 rounded-full blur-[90px] animate-orb-c pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] bg-violet-900/8 rounded-full blur-[130px] pointer-events-none"></div>

    <!-- Grid overlay -->
    <div
      class="absolute inset-0 opacity-[0.06]"
      style="background-image: linear-gradient(rgba(148,163,184,0.6) 1px, transparent 1px), linear-gradient(90deg, rgba(148,163,184,0.6) 1px, transparent 1px); background-size: 64px 64px;"
    ></div>
  </div>

  <div class="max-w-6xl mx-auto px-6 py-20 relative z-10 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- ── Left: Content ── -->
      <div>
        <!-- Status pill -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-violet-500/10 border border-violet-500/25 mb-7 backdrop-blur-sm">
          <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
          <span class="font-mono text-xs text-violet-300 tracking-widest uppercase">Open to opportunities</span>
        </div>

        <!-- Name in Delius -->
        <h1 class="font-display text-6xl sm:text-7xl leading-[1.1] mb-5">
          <span class="text-white">Amatullah</span><br />
          <span class="gradient-text">Bharmal</span>
        </h1>

        <!-- Typewriter role -->
        <div class="flex items-center gap-3 mb-7 min-h-[2rem]">
          <div class="h-px w-8 bg-gradient-to-r from-violet-500 to-blue-500 shrink-0"></div>
          <h2 class="text-xl sm:text-2xl font-medium text-slate-300">
            <span id="typewriter"></span><span class="typewriter-cursor">|</span>
          </h2>
        </div>

        <p class="text-slate-400 text-lg leading-relaxed mb-9 max-w-lg">
          I build beautiful, high-performance mobile apps for
          <span class="text-slate-200 font-medium">Android &amp; iOS</span>
          using React Native, Expo, and Firebase — currently at
          <span class="text-violet-300 font-medium">Wowsly</span>.
        </p>

        <!-- Social links -->
        <div class="flex items-center gap-2 mb-10">
          <a
            href="https://github.com/amatullah2"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-500 hover:text-white transition-all duration-200 p-2.5 rounded-xl hover:bg-slate-800 hover:shadow-lg"
            title="GitHub"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/amatullah-bharmal/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-500 hover:text-blue-400 transition-all duration-200 p-2.5 rounded-xl hover:bg-slate-800 hover:shadow-lg"
            title="LinkedIn"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
          <a
            href="mailto:amatullahbharmal3@gmail.com"
            class="text-slate-500 hover:text-violet-400 transition-all duration-200 p-2.5 rounded-xl hover:bg-slate-800 hover:shadow-lg"
            title="Email"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
        </div>

        <!-- CTA buttons -->
        <div class="flex flex-wrap gap-4">
          <a href="#projects" class="btn-primary">
            View My Work
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/Amatullah_Resume.pdf" download class="btn-outline">
            Download Resume
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- ── Right: Photo with spinning ring ── -->
      <div class="flex justify-center lg:justify-end">
        <div class="relative">

          <!-- Outer ambient glow -->
          <div
            class="absolute inset-0 rounded-full bg-gradient-to-br from-violet-600 to-blue-600 blur-3xl opacity-20 scale-125 animate-pulse-slow pointer-events-none"
          ></div>

          <!-- Floating container (bobs up/down) -->
          <div class="relative animate-float">

            <!-- Spinning conic ring layer -->
            <div
              class="spin-ring-outer absolute -inset-[3px] rounded-full"
            ></div>

            <!-- Photo (sits on top, doesn't spin) -->
            <div class="relative w-64 h-64 sm:w-72 sm:h-72 rounded-full overflow-hidden bg-slate-950">
              <img
                src="/profile.jpg"
                alt="Amatullah Bharmal"
                class="w-full h-full object-cover object-top"
                loading="eager"
              />
            </div>

            <!-- Available badge -->
            <div
              class="absolute -bottom-2 -right-2 sm:bottom-2 sm:right-0 bg-slate-900/90 backdrop-blur-sm border border-slate-700/80 rounded-full px-4 py-2 flex items-center gap-2 shadow-2xl"
            >
              <span class="w-2.5 h-2.5 bg-emerald-400 rounded-full animate-pulse"></span>
              <span class="text-xs font-medium text-slate-300">Available for hire</span>
            </div>
          </div>

          <!-- Floating skill chips (hidden on small screens to avoid overflow) -->
          <div
            class="hidden sm:flex absolute -top-5 -left-10 items-center gap-2 bg-slate-900/85 backdrop-blur-sm border border-violet-500/30 rounded-full px-3 py-1.5 shadow-xl animate-float"
            style="animation-delay: 0.8s; animation-duration: 7s;"
          >
            <span class="text-base">📱</span>
            <span class="text-xs font-medium text-violet-300">React Native</span>
          </div>

          <div
            class="hidden sm:flex absolute top-1/3 -right-16 items-center gap-2 bg-slate-900/85 backdrop-blur-sm border border-blue-500/30 rounded-full px-3 py-1.5 shadow-xl animate-float"
            style="animation-delay: 2s; animation-duration: 8s;"
          >
            <span class="text-base">🔥</span>
            <span class="text-xs font-medium text-blue-300">Firebase</span>
          </div>

          <div
            class="hidden sm:flex absolute bottom-14 -left-14 items-center gap-2 bg-slate-900/85 backdrop-blur-sm border border-emerald-500/30 rounded-full px-3 py-1.5 shadow-xl animate-float"
            style="animation-delay: 1.4s; animation-duration: 6.5s;"
          >
            <span class="text-base">⚡</span>
            <span class="text-xs font-medium text-emerald-300">Expo</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-50">
      <span class="text-xs font-mono text-slate-500 tracking-widest uppercase">Scroll</span>
      <div class="w-px h-12 bg-gradient-to-b from-violet-400 to-transparent animate-pulse"></div>
    </div>
  </div>
</section>

<script>
  // Typewriter effect cycling through roles
  const roles = [
    'React Native Developer',
    'Mobile App Developer',
    'Cross-Platform Expert',
  ];

  const el = document.getElementById('typewriter') as HTMLElement | null;
  if (el) {
    let current = 0, char = 0, deleting = false;

    function type() {
      const word = roles[current];
      if (!deleting) {
        el!.textContent = word.slice(0, ++char);
        if (char === word.length) {
          deleting = true;
          setTimeout(type, 2400);
          return;
        }
      } else {
        el!.textContent = word.slice(0, --char);
        if (char === 0) {
          deleting = false;
          current = (current + 1) % roles.length;
        }
      }
      setTimeout(type, deleting ? 42 : 88);
    }

    setTimeout(type, 500);
  }
</script>
