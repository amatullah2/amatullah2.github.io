---
---

<section id="certifications" class="py-24 relative">
  <div class="max-w-6xl mx-auto px-6">
    <div data-animate>
      <span class="section-label">05. education & certifications</span>
      <h2 class="section-title">Qualifications</h2>
      <div class="section-bar"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Education Card -->
      <div data-animate class="card p-8 relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-32 h-32 bg-blue-600/5 rounded-full blur-2xl group-hover:bg-blue-600/10 transition-colors pointer-events-none"></div>

        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-xl">
            🎓
          </div>
          <span class="text-xs font-mono text-blue-400 uppercase tracking-widest">Education</span>
        </div>

        <h3 class="text-xl font-bold text-white mb-1">
          Bachelor of Engineering
        </h3>
        <p class="text-blue-400 font-semibold mb-1">Computer Science & Engineering</p>
        <p class="text-slate-400 text-sm mb-5">SLTIET, Gujarat</p>

        <div class="flex items-center gap-6 mb-5">
          <div>
            <p class="text-xs text-slate-500 font-mono uppercase tracking-wide mb-0.5">Duration</p>
            <p class="text-slate-300 font-medium text-sm">Oct 2021 – May 2025</p>
          </div>
          <div>
            <p class="text-xs text-slate-500 font-mono uppercase tracking-wide mb-0.5">CGPA</p>
            <p class="text-2xl font-extrabold gradient-text">8.58</p>
          </div>
        </div>

        <div class="flex flex-wrap gap-2">
          {['Data Structures', 'Algorithms', 'DBMS', 'Operating Systems', 'Networks'].map((sub) => (
            <span class="text-xs px-2.5 py-1 rounded-md bg-blue-500/10 text-blue-300 border border-blue-500/20">
              {sub}
            </span>
          ))}
        </div>
      </div>

      <!-- Certification Card -->
      <div data-animate style="transition-delay: 100ms" class="card p-8 relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-32 h-32 bg-violet-600/5 rounded-full blur-2xl group-hover:bg-violet-600/10 transition-colors pointer-events-none"></div>

        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl bg-violet-500/10 border border-violet-500/20 flex items-center justify-center text-xl">
            📜
          </div>
          <span class="text-xs font-mono text-violet-400 uppercase tracking-widest">Certification</span>
        </div>

        <h3 class="text-xl font-bold text-white mb-1">
          React Native Certification
        </h3>
        <p class="text-violet-400 font-semibold mb-1">Tutedude</p>
        <p class="text-slate-400 text-sm mb-5">3-Month Intensive Course</p>

        <p class="text-slate-400 text-sm leading-relaxed mb-5">
          Completed a comprehensive 3-month React Native certification with hands-on project-based learning covering the full mobile development lifecycle.
        </p>

        <div class="flex flex-wrap gap-2">
          {[
            'React Native',
            'Expo',
            'Firebase Auth',
            'Real-time Database',
            'Local Notifications',
            'App Deployment',
          ].map((topic) => (
            <span class="text-xs px-2.5 py-1 rounded-md bg-violet-500/10 text-violet-300 border border-violet-500/20">
              {topic}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
