---

<section id="contact" class="py-24 relative">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-slate-900/20 to-transparent pointer-events-none"></div>

  <div class="max-w-4xl mx-auto px-6 text-center relative">
    <div data-animate>
      <span class="section-label" style="display: block; text-align: center;">06. contact</span>
      <h2 class="section-title">Let's Connect</h2>
      <div class="section-bar mx-auto"></div>
    </div>

    <p data-animate class="text-slate-400 text-lg leading-relaxed mb-12 max-w-2xl mx-auto">
      I'm actively looking for new opportunities — full-time roles, freelance projects, and
      collaborations. Whether you have a question or just want to say hi, my inbox is always open!
    </p>

    <!-- Contact Links -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-12">
      {
        links.map((link, i) => (
          <a
            data-animate
            style={`transition-delay: ${i * 80}ms`}
            href={link.href}
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class={`card p-6 flex flex-col items-center gap-3 text-center bg-gradient-to-br ${link.color} border ${link.border} group transition-all duration-300`}
          >
            <div class={`${link.iconColor} group-hover:scale-110 transition-transform`} set:html={link.icon} />
            <div>
              <p class="text-white font-semibold text-sm mb-0.5">{link.label}</p>
              <p class="text-slate-500 text-xs font-mono break-all">{link.value}</p>
            </div>
            <p class="text-slate-600 text-xs">{link.description}</p>
          </a>
        ))
      }
    </div>

    <!-- Primary CTA -->
    <div data-animate>
      <a href="mailto:amatullahbharmal3@gmail.com" class="btn-primary text-base px-8 py-4">
        Say Hello
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </a>
    </div>
  </div>
</section>
