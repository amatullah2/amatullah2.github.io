---
const projects = [
  {
    number: '01',
    title: 'Amrut',
    subtitle: 'B2B Gold Manufacturing Platform',
    description:
      'A specialized B2B mobile application for gold manufacturers with role-based catalog access, time-bound client access, and streamlined order management.',
    tech: ['React Native', 'Firebase', 'Role-based Auth', 'Expo'],
    featured: true,
  },
  {
    number: '02',
    title: 'Premvati',
    subtitle: 'Food Delivery App',
    description:
      'A mobile food delivery application for ordering fast food, traditional sweets, and snacks with order tracking and serving options.',
    tech: ['React Native', 'Expo', 'Firebase', 'REST API'],
    featured: true,
  },
  {
    number: '03',
    title: 'Expense Tracker',
    subtitle: 'Personal Finance App',
    description:
      'A personal finance app with secure Firebase authentication, real-time expense tracking, transaction history, and insightful summaries.',
    tech: ['React Native', 'Firebase Auth', 'Firestore', 'Expo'],
    featured: true,
  },
  {
    number: '04',
    title: 'YBGO',
    subtitle: 'Taxi Booking App',
    description:
      'A taxi booking application designed to provide users with a smooth and seamless ride-booking experience with driver matching.',
    tech: ['React Native', 'Expo', 'Maps API', 'Firebase'],
    featured: false,
  },
  {
    number: '05',
    title: 'Option Game',
    subtitle: 'Stock Market Learning App',
    description:
      'An interactive stock market learning app that helps users understand options trading concepts through gamified simulations.',
    tech: ['React Native', 'JavaScript', 'Expo'],
    featured: false,
  },
  {
    number: '06',
    title: 'QR Police Feedback',
    subtitle: 'Hackathon Project',
    description:
      'A hackathon project to improve transparency between citizens and the government through QR-code-based feedback collection for Gujarat Police.',
    tech: ['React Native', 'QR Code', 'Firebase', 'Expo'],
    featured: false,
  },
  {
    number: '07',
    title: 'Tic Tac Toe',
    subtitle: '2-Player Mobile Game',
    description:
      'A polished 2-player Tic Tac Toe game built with React Native and Expo featuring win/draw detection, score tracking, and smooth animations.',
    tech: ['React Native', 'Expo', 'Animations'],
    featured: false,
  },
  {
    number: '08',
    title: 'Amazon Clone',
    subtitle: 'E-commerce UI Clone',
    description:
      'A pixel-perfect clone of the Amazon e-commerce website home page built using semantic HTML and responsive CSS.',
    tech: ['HTML', 'CSS', 'Responsive Design'],
    featured: false,
  },
];
---

<section id="projects" class="py-24 relative">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-slate-900/20 to-transparent pointer-events-none"></div>

  <div class="max-w-6xl mx-auto px-6 relative">
    <div data-animate>
      <span class="section-label">04. projects</span>
      <h2 class="section-title">Things I've Built</h2>
      <div class="section-bar"></div>
    </div>

    <!-- Featured Projects -->
    <div class="space-y-6 mb-12">
      {
        projects
          .filter((p) => p.featured)
          .map((project, i) => (
            <div
              data-animate
              style={`transition-delay: ${i * 100}ms`}
              class="card p-6 md:p-8 group"
            >
              <div class="flex flex-col md:flex-row gap-6 items-start">
                <div class="shrink-0">
                  <span class="font-mono text-5xl font-extrabold text-slate-800 group-hover:text-slate-700 transition-colors select-none">
                    {project.number}
                  </span>
                </div>
                <div class="flex-1">
                  <div class="flex items-start justify-between gap-4 mb-2">
                    <div>
                      <span class="text-xs font-mono text-violet-400 uppercase tracking-widest block mb-1">
                        Featured Project
                      </span>
                      <h3 class="text-xl font-bold text-white group-hover:text-violet-200 transition-colors">
                        {project.title}
                      </h3>
                      <p class="text-slate-500 text-sm font-medium">{project.subtitle}</p>
                    </div>
                  </div>
                  <p class="text-slate-400 text-sm leading-relaxed mb-4">{project.description}</p>
                  <div class="flex flex-wrap gap-2">
                    {project.tech.map((t) => (
                      <span class="text-xs px-2.5 py-1 rounded-md bg-violet-500/10 text-violet-300 border border-violet-500/20 font-mono">
                        {t}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ))
      }
    </div>

    <!-- Other Projects Grid -->
    <h3 class="text-sm font-mono text-slate-500 uppercase tracking-widest mb-6 text-center">Other Noteworthy Projects</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        projects
          .filter((p) => !p.featured)
          .map((project, i) => (
            <div
              data-animate
              style={`transition-delay: ${i * 80}ms`}
              class="card p-5 flex flex-col group"
            >
              <div class="flex items-start justify-between mb-3">
                <span class="font-mono text-3xl font-extrabold text-slate-800 group-hover:text-slate-700 transition-colors select-none">
                  {project.number}
                </span>
                <svg class="w-5 h-5 text-slate-700 group-hover:text-violet-500 transition-colors mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </div>
              <h3 class="text-base font-bold text-white mb-1 group-hover:text-violet-200 transition-colors">
                {project.title}
              </h3>
              <p class="text-xs text-slate-500 font-medium mb-3">{project.subtitle}</p>
              <p class="text-slate-400 text-sm leading-relaxed mb-4 flex-1">{project.description}</p>
              <div class="flex flex-wrap gap-1.5 mt-auto">
                {project.tech.map((t) => (
                  <span class="text-xs px-2 py-0.5 rounded font-mono text-slate-500 bg-slate-800/60">
                    {t}
                  </span>
                ))}
              </div>
            </div>
          ))
      }
    </div>
  </div>
</section>
